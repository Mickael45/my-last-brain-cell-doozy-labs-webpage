---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import RevealObserver from "../../components/RevealObserver";

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown>[];
}

const { title, description, ogTitle, ogImage, ogType, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-gray-900">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogTitle={ogTitle}
      ogImage={ogImage}
      ogType={ogType}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-gray-900 text-white">
    <slot />
    {/* Reveal-on-scroll observer for [data-reveal] elements (zero-JS until idle) */}
    <RevealObserver client:idle />
  </body>
</html>
